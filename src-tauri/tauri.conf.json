{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Visual GUI Proxy",
  "version": "0.0.1",
  "identifier": "com.weronnip.vgp",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Visual GUI Proxy",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyMzg1N0ZCRDA3Mzg5REIKUldUYmlYUFErMWM0UWlvcWNXR29IMG5iL1dTZitxcUxzb0tkakVFVnJVdGlvQlZyOGQxNXhFdlgK",
      "endpoints": [
        "https://github.com/Logbin05/VGP/releases/latest/download/latest.json"
      ]
    }
  }
}
